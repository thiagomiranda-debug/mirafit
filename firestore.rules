rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: so podem ler/escrever seu proprio perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Exercicios da biblioteca: leitura publica para usuarios autenticados
    match /library_exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if false; // Apenas via Admin SDK (seed)
    }

    // Treinos: usuario so acessa seus proprios treinos e rotinas
    match /workouts/{workoutId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow write: if false; // Apenas via API Route (Admin SDK)

      match /routines/{routineId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/workouts/$(workoutId)).data.user_id == request.auth.uid;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/workouts/$(workoutId)).data.user_id == request.auth.uid;
      }
    }

    // Historico de treinos: imutavel apos criacao, so o dono acessa
    match /workout_history/{logId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid
        && (!("workout_id" in request.resource.data)
          || get(/databases/$(database)/documents/workouts/$(request.resource.data.workout_id)).data.user_id == request.auth.uid);
      allow update: if false;
      allow delete: if false;
    }

    // Tentativas de TAF: imutaveis apos criacao, so o dono acessa
    match /taf_attempts/{attemptId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // Medidas corporais: imutaveis apos criacao, so o dono acessa
    match /body_measurements/{measurementId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // Sessoes de cardio: imutaveis apos criacao (para corrigir, cria uma nova).
    // Delete e permitido pois o hub /cardio expoe remocao das ultimas sessoes.
    match /cardio_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
